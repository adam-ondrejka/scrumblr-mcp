# Origin only (no path), e.g. https://scrumblr.your-internal-host
SCRUMBLR_URL=https://scrumblr.your-internal-host
# Board id = the URL segment after the origin, e.g. team-retro-q2
SCRUMBLR_BOARD=team-retro-q2

# If the server runs under a sub-path, set it here (matches `conf.baseurl`).
# SCRUMBLR_BASEURL=/

# Set this only if the snapshot CLI fails with a connect/handshake error
# that looks like auth. Capture from a logged-in browser:
#   devtools → Network → any request to the scrumblr host
#   → copy the entire `cookie:` request header value here.
# SCRUMBLR_COOKIE=

# Snapshot cache TTL in ms (default 30000).
# SCRUMBLR_CACHE_MS=30000
