# Required: origin of the scrumblr server (no path), e.g. https://scrumblr.example.com
SCRUMBLR_URL=https://scrumblr.your-internal-host

# Required: board id = the URL segment after the origin, e.g. team-retro-q2
SCRUMBLR_BOARD=team-retro-q2

# Optional: sub-path the scrumblr server runs under (matches `conf.baseurl`).
# SCRUMBLR_BASEURL=/

# Optional: Cookie header for auth-gated servers. Capture from a logged-in
# browser:
#   devtools → Network → any request to the scrumblr host
#   → copy the entire `cookie:` request header value here.
# SCRUMBLR_COOKIE=

# Optional: snapshot cache TTL in ms (default 30000).
# SCRUMBLR_CACHE_MS=30000

# Optional: Jira-style project prefix used to detect story cards (default any
# uppercase prefix). Set to a specific project to narrow detection, e.g.
#   SCRUMBLR_JIRA_PREFIX=PROJ
# SCRUMBLR_JIRA_PREFIX=
